# ─── Venice (required for synthesis layer) ───────────────────────────────────
# Get an API key at: https://venice.ai/settings/api
# Important: a fresh Venice account authenticates but needs credits to fulfill
# API calls. Add ~$5 USD via Settings → Add Credits (covers ~1000 test runs).
VENICE_API_KEY=

# ─── Solvr (optional — only needed for tier-gated intels) ────────────────────
# Free-tier intels like narrative-tracker and morning-brief work without this.
# For token-report and other standard/full tier intels, either:
#   1. Register via examples/register.py with your wallet, or
#   2. Pull an existing key if you already have admin access to Solvr
SOLVR_API_KEY=

# ─── Wallet (only for examples/register.py one-time registration) ────────────
# Used by register.py to sign the agent registration message.
# Use a fresh wallet or your dev wallet — never a wallet with significant holdings.
SOLVR_WALLET=
SOLVR_PRIVATE_KEY=
